{
  "name": "cuevue",
  "version": "1.0.0",
  "productName": "CueVue",
  "author": "Smokey River Studio",
  "description": "CueVue - Professional Demo Scene Controller",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:mac-dir": "electron-builder --mac dir",
    "build:dmg": "electron-builder --mac dmg",
    "build:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac -c.mac.identity=null"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cuevue.app",
    "productName": "CueVue",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dir",
        "dmg"
      ],
      "icon": "buildResources/icon.icns",
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "entitlements": "buildResources/entitlements.mac.plist",
      "entitlementsInherit": "buildResources/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "CueVue needs Screen Recording access to capture windows for the iPhone scene.",
        "NSMicrophoneUsageDescription": "CueVue does not use the microphone.",
        "NSCameraUsageDescription": "CueVue does not use the camera."
      }
    },
    "afterSign": "scripts/notarize.js",
    "dmg": {
      "title": "CueVue ${version}",
      "format": "UDZO",
      "size": "1200m",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "output": "dist",
      "buildResources": "buildResources"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "splash.html",
      "package.json"
    ]
  }
}
