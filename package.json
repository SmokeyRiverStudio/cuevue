{
  "name": "cuevue",
  "version": "0.2.13",
  "productName": "CueVue",
  "author": "Smokey River Studio",
  "description": "CueVue - Professional Demo Scene Controller",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dir",
    "build:mac-dir": "electron-builder --mac dir",
    "build:dmg": "electron-builder --mac dmg --publish never",
    "build:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir -c.mac.identity=null -c.mac.hardenedRuntime=false && codesign --force --deep --sign - dist/mac-arm64/CueVue.app"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cuevue.app",
    "productName": "CueVue",
    "artifactName": "CueVue-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.business",
      "target": "dir",
      "identity": null,
      "icon": "buildResources/icon.icns",
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "CueVue needs Screen Recording access to capture windows for the iPhone scene.",
        "NSMicrophoneUsageDescription": "CueVue does not use the microphone.",
        "NSCameraUsageDescription": "CueVue does not use the camera."
      }
    },
    "publish": null,
    "dmg": {
      "title": "CueVue ${version}",
      "icon": "buildResources/icon.icns",
      "format": "UDZO",
      "size": "1200m",
      "contents": [
        {"x": 130, "y": 220},
        {"x": 410, "y": 220, "type": "link", "path": "/Applications"}
      ]
    },
    "directories": {"output": "dist", "buildResources": "buildResources"},
    "files": ["main.js", "preload.js", "index.html", "splash.html", "package.json", "buildResources/icon-source.png"]
  }
}
